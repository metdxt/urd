# sum.urd — sum of integers 1 to 10000 benchmark
#
# Measures simple accumulator loop throughput in urd.
# Computes 1 + 2 + 3 + ... + 10000
#
# Expected output:  sum(10000) = 50005000

const narrator = :{ name: "Narrator", name_color: "white" }

global i   = 1
global sum = 0

@entry
label sum_loop {
    sum = sum + i
    i   = i + 1

    if i <= 10000 {
        jump sum_loop
    }

    narrator: "sum(10000) = {sum}"
    end!()
}
