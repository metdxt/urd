digraph urd_script {
    rankdir=TB;
    splines=ortho;
    node [fontname="monospace", fontsize=11];
    edge [fontname="monospace", fontsize=9];

    __start__ [label="▶ START", shape=invhouse, style="filled,bold", fillcolor="#1b4332", fontcolor=white, fontsize=12, margin="0.15,0.1"];
    __start__ -> N55;

    subgraph cluster_start {
        label="start";
        style="rounded,filled";
        fillcolor="#f0fff4";
        color=darkgreen;
        penwidth=3.0;

        N0 [label="▶ start", shape=cds, style=filled, fillcolor="palegreen"];
        N37 [label="jump → talk", shape=rarrow, style=filled, fillcolor="wheat"];
        N38 [label="jump → notice_board", shape=rarrow, style=filled, fillcolor="wheat"];
        N39 [label="return", shape=box, style=filled, fillcolor="mistyrose"];
        N40 [label="Narrator:\n\"You step back out into the cold ni…\"\n@voiced", shape=box, style=filled, fillcolor="lightsalmon"];
        N41 [label="choice (3 opts)\n@important", shape=hexagon, style=filled, fillcolor="plum"];
        N42 [label="⤑ log_visit", shape=rarrow, style=filled, fillcolor="wheat"];
        N43 [label="⤑ compute_rank\n→ rank", shape=rarrow, style=filled, fillcolor="wheat"];
        N45 [label="Innkeeper:\n\"Ah, a friendly face! Welcome back.\"", shape=box, style=filled, fillcolor="lightsalmon"];
        N47 [label="Innkeeper:\n\"I'm watching you, stranger.\"", shape=box, style=filled, fillcolor="lightsalmon"];
        N48 [label="Innkeeper:\n\"What do you want?\"", shape=box, style=filled, fillcolor="lightsalmon"];
        N49 [label="branch\nreputati… LessThan 0", shape=diamond, style=filled, fillcolor="lightyellow"];
        N50 [label="branch\nreputati… GreaterThan 10", shape=diamond, style=filled, fillcolor="lightyellow"];
        N51 [label="Narrator:\n\"You push open the heavy oak door a…\"\n@voiced @timed", shape=box, style=filled, fillcolor="lightsalmon"];
    }

    subgraph cluster_talk {
        label="talk";
        style="rounded,filled";
        fillcolor="#f0fff4";
        color=darkgreen;
        penwidth=1.5;

        N1 [label="▶ talk", shape=cds, style=filled, fillcolor="palegreen"];
        N27 [label="jump → start", shape=rarrow, style=filled, fillcolor="wheat"];
        N28 [label="Innkeeper:\n\"They say the old mill is haunted n…\"", shape=box, style=filled, fillcolor="lightsalmon"];
        N29 [label="let reputation = ⟨expr⟩", shape=box, style=filled, fillcolor="lightcyan"];
        N30 [label="jump → start", shape=rarrow, style=filled, fillcolor="wheat"];
        N31 [label="Innkeeper:\n\"Two gold. Pay up.\"", shape=box, style=filled, fillcolor="lightsalmon"];
        N32 [label="let cost = ⟨expr⟩", shape=box, style=filled, fillcolor="lightcyan"];
        N33 [label="jump → start", shape=rarrow, style=filled, fillcolor="wheat"];
        N34 [label="choice (3 opts)", shape=hexagon, style=filled, fillcolor="plum"];
        N35 [label="Innkeeper:\n\"What can I do for you?\"\n\"Don't keep me waiting.\"\n@voiced", shape=box, style=filled, fillcolor="lightsalmon"];
    }

    subgraph cluster_notice_board {
        label="notice_board";
        style="rounded,filled";
        fillcolor="#f0fff4";
        color=darkgreen;
        penwidth=1.5;

        N2 [label="▶ notice_board", shape=cds, style=filled, fillcolor="palegreen"];
        N17 [label="jump → start", shape=rarrow, style=filled, fillcolor="wheat"];
        N19 [label="let reputation = ⟨expr⟩", shape=box, style=filled, fillcolor="lightcyan"];
        N20 [label="Narrator:\n\"You tear the notices from the boar…\"", shape=box, style=filled, fillcolor="lightsalmon"];
        N21 [label="let reputation = ⟨expr⟩", shape=box, style=filled, fillcolor="lightcyan"];
        N22 [label="Narrator:\n\"You study the bounty posters caref…\"", shape=box, style=filled, fillcolor="lightsalmon"];
        N23 [label="Narrator:\n\"You glance at the board and move o…\"", shape=box, style=filled, fillcolor="lightsalmon"];
        N24 [label="match (3 arms)", shape=diamond, style=filled, fillcolor="lightyellow"];
        N25 [label="let action = ⟨expr⟩", shape=box, style=filled, fillcolor="lightcyan"];
    }

    subgraph cluster_compute_rank {
        label="compute_rank";
        style="rounded,filled";
        fillcolor="#f0fff4";
        color=darkgreen;
        penwidth=1.5;

        N3 [label="▶ compute_rank", shape=cds, style=filled, fillcolor="palegreen"];
        N9 [label="return ⟨expr⟩", shape=box, style=filled, fillcolor="mistyrose"];
        N11 [label="return ⟨expr⟩", shape=box, style=filled, fillcolor="mistyrose"];
        N12 [label="branch\nreputati… LessThan 0", shape=diamond, style=filled, fillcolor="lightyellow"];
        N14 [label="return ⟨expr⟩", shape=box, style=filled, fillcolor="mistyrose"];
        N15 [label="branch\nreputati… GreaterThan 10", shape=diamond, style=filled, fillcolor="lightyellow"];
    }

    subgraph cluster_log_visit {
        label="log_visit";
        style="rounded,filled";
        fillcolor="#f0fff4";
        color=darkgreen;
        penwidth=1.5;

        N4 [label="▶ log_visit", shape=cds, style=filled, fillcolor="palegreen"];
        N6 [label="return", shape=box, style=filled, fillcolor="mistyrose"];
        N7 [label="Narrator:\n\"Your visit has been recorded in th…\"", shape=box, style=filled, fillcolor="lightsalmon"];
    }

    N52 [label="def_decorator\n@timed (2 params)", shape=box, style=filled, fillcolor="#E6E6FA"];
    N53 [label="enum Action (3 variants)", shape=box, style=filled, fillcolor="lavender"];
    N54 [label="const max_health = ⟨expr⟩", shape=box, style=filled, fillcolor="lightcyan"];
    N55 [label="global reputation = ⟨expr⟩", shape=box, style=filled, fillcolor="lightcyan"];

    N0 -> N51;
    N1 -> N35;
    N2 -> N25;
    N3 -> N15;
    N4 -> N7;
    N6 -> N41 [style=dashed, color=darkslateblue, constraint=false, label="↩"];
    N7 -> N6;
    N9 -> N42 [style=dashed, color=darkslateblue, constraint=false, label="↩"];
    N11 -> N42 [style=dashed, color=darkslateblue, constraint=false, label="↩"];
    N12 -> N11 [label="then"];
    N12 -> N9 [label="else", style=dashed];
    N14 -> N42 [style=dashed, color=darkslateblue, constraint=false, label="↩"];
    N15 -> N14 [label="then"];
    N15 -> N12 [label="else", style=dashed];
    N17 -> N0 [style=dashed, color=gray40, constraint=false];
    N19 -> N17;
    N20 -> N19;
    N21 -> N17;
    N22 -> N21;
    N23 -> N17;
    N24 -> N20 [label="Action.Attack"];
    N24 -> N22 [label="Action.Talk"];
    N24 -> N23 [label="default", style=dashed];
    N25 -> N24;
    N27 -> N0 [style=dashed, color=gray40, constraint=false];
    N28 -> N27;
    N29 -> N28;
    N30 -> N0 [style=dashed, color=gray40, constraint=false];
    N31 -> N30;
    N32 -> N31;
    N33 -> N0 [style=dashed, color=gray40, constraint=false];
    N34 -> N29 [label="[0] Ask about local rumours", color=purple];
    N34 -> N32 [label="[1] Buy a drink", color=purple];
    N34 -> N33 [label="[2] Never mind", color=purple];
    N35 -> N34;
    N37 -> N1 [style=dashed, color=gray40, constraint=false];
    N38 -> N2 [style=dashed, color=gray40, constraint=false];
    N39 -> __end__ [style=dashed, color=gray40];
    N40 -> N39;
    N41 -> N37 [label="[0] Talk to the innkeeper", color=purple];
    N41 -> N38 [label="[1] Check the notice board", color=purple];
    N41 -> N40 [label="[2] Leave the tavern", color=purple];
    N42 -> N4 [style=dashed, color=gray40, constraint=false, label="call"];
    N42 -> N41 [style=dashed, color=darkslateblue, label="ret"];
    N43 -> N3 [style=dashed, color=gray40, constraint=false, label="call"];
    N43 -> N42 [style=dashed, color=darkslateblue, label="ret"];
    N45 -> N43;
    N47 -> N43;
    N48 -> N43;
    N49 -> N47 [label="then"];
    N49 -> N48 [label="else", style=dashed];
    N50 -> N45 [label="then"];
    N50 -> N49 [label="else", style=dashed];
    N51 -> N50;
    N52 -> N0;
    N53 -> N52;
    N54 -> N53;
    N55 -> N54;

    __end__ [label="END", shape=doublecircle, style=filled, fillcolor=tomato, fontcolor=white];

}
