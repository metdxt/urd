## label: browse
# @fluent variables: $has_potion (urd: has_potion), $price (urd: price), $gold (urd: gold), $item (urd: item)
# $item to identyfikator przedmiotu (np. "health_potion") — użyj selektora, by uzyskać
# poprawną formę gramatyczną.  Dodaj nowe ramię dla każdego nowego przedmiotu w grze.

# menu: merchant-browse-menu_1
# Biernik — przedmiot jest dopełnieniem bliższym czasownika "kup".
merchant-browse-menu_1-buy_it_for_price_gold =
    Kup { $item ->
        [health_potion] miksturę zdrowia
        [mana_potion]   miksturę many
       *[other]         { $item }
    } za { $price ->
        [one]   { $price } złoty
        [few]   { $price } złote
       *[other] { $price } złotych
    }
merchant-browse-menu_1-try_to_haggle = Spróbuj się potargować
merchant-browse-menu_1-never_mind = Nieważne

# interpolation: $price
# $item jest wstrzykiwany przez @fluent — selektor poniżej mapuje go na formę mianownikową.
# "Oto:" wymaga mianownika: "mikstura zdrowia", NIE biernika "miksturę zdrowia".
merchant-browse-line_1 =
    Oto: { $item ->
        [health_potion] mikstura zdrowia
        [mana_potion]   mikstura many
       *[other]         { $item }
    }! Proszę { $price ->
        [one]   { $price } złoty — to prawdziwa okazja.
        [few]   { $price } złote — to prawdziwa okazja.
       *[other] { $price } złotych — to prawdziwa okazja.
    }

