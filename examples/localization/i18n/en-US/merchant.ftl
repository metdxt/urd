merchant-start-line_1 = Welcome! I am Elara, purveyor of fine curiosities.
    Might I interest you in a Health Potion today?

merchant-start-line_2 = You step into the Wandering Bazaar.
    Canvas stalls stretch in every direction, lit by swaying lanterns.

## label: browse
# @fluent variables: $has_potion (urd: has_potion), $price (urd: price), $gold (urd: gold), $item (urd: item)
# $item carries an item ID slug (e.g. "health_potion").  Use a selector to map it
# to a display name.  Add a new arm for every item the merchant can sell.

# menu: merchant-browse-menu_1
# $item selector used here too — English happens to use the same form in all positions,
# but other locales may need accusative/genitive case in a buy prompt.
merchant-browse-menu_1-buy_it_for_price_gold =
    Buy the { $item ->
        [health_potion] Health Potion
        [mana_potion]   Mana Potion
       *[other]         { $item }
    } for { $price } gold
merchant-browse-menu_1-try_to_haggle = Try to haggle
merchant-browse-menu_1-never_mind = Never mind

# interpolation: $price
# $item is injected via @fluent — resolved through the selector below, not raw substitution.
merchant-browse-line_1 =
    Behold: the { $item ->
        [health_potion] Health Potion
        [mana_potion]   Mana Potion
       *[other]         { $item }
    }! I ask { $price } gold — a true bargain.

